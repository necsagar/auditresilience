#!/bin/bash

if (( $# != 2 )); then
    echo "Usage: $0 <number_of_parallel_tasks> <loops_per_task> <mode>"
    echo "  mode = ok   (valid chmod on a real file)"
    echo "       = fail (fast-fail chmod on nonexistent path)"
    exit 1
fi

tasks=$1         # Number of parallel tasks (processes)
loops=$2         # Number of chmod() calls per task
# mode=$3        # ok | fail
# mode="fail"      # making this as default, so no need to pass from bmrunall
mode="ok"
cd chmod || { echo "chmod directory not found"; exit 1; }
make all || { echo "build failed"; exit 1; }
echo "Running $tasks parallel chmod storm tasks, $loops loops each, mode=$mode"

do_chmod_storm() {
    task_id=$1
    loops=$2
    mode=$3
    echo "Task $task_id starting..."
    ./bin/chmodcode "$loops" "$mode"
    echo "Task $task_id  done."
}

time (
    for (( i=0; i < tasks; i++ )); do
        (do_chmod_storm "$i" "$loops" "$mode") &
    done
    wait
)
