#!/bin/bash

if (( $# < 1 || $# > 4 )); then
    echo "Usage: $0 <datafilename> [per_cpu_buffer [wakeup_interval [cgroup_quota]]]" && exit 1
fi

outfile="$1"
per_cpu_buffer=$2
wakeup_interval=$3
cgroup_quota=${4:-80000}

if [[ "${outfile##*.}" != "csv" ]]; then
    echo "data file name should have a csv suffix" && exit 1
fi

# ---------- Keep sudo alive for the entire run ----------                       
if [[ $EUID -ne 0 ]]; then                                                       
  echo -n  "Requesting sudo once and keeping it alive for the duration..."            
  sudo -v || die "sudo authentication failed."                                   
  # Refresh sudo timestamp every 60s in the background, until this script exits. 
  # If the timestamp ever expires (e.g., sudoers changed), sudo -n will fail.       
  keep_sudo_fresh() { while sleep 60; do sudo -n true || exit; done; }           
  keep_sudo_fresh & SUDO_KEEPALIVE_PID=$!                                        
  trap '[[ -n "${SUDO_KEEPALIVE_PID:-}" ]] && kill "$SUDO_KEEPALIVE_PID" 2>/dev/null || true' EXIT
fi 

