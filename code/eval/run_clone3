#!/bin/bash

if (( $# != 2 )); then
    echo "Usage: $0 <number_of_parallel_tasks> <loops_per_task>"
    exit 1
fi

tasks=$1         # Number of parallel tasks (processes)
loops=$2         # Number of clone3() calls per task

cd clone3 || { echo "clone3 directory not found"; exit 1; }
make all || { echo "build failed"; exit 1; }

echo "Running $tasks parallel clone3-fail storm tasks, $loops loops each"

do_clone3_storm() {
    task_id=$1
    loops=$2
    echo "Task $task_id starting..."
    ./bin/clone3code "$loops"
    echo "Task $task_id done."
}

time (
    for (( i=0; i < tasks; i++ )); do
        (do_clone3_storm "$i" "$loops") &
    done
    wait
)
